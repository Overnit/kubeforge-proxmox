# ============================================================
# Proxmox Homelab - Terraform Variables
# ============================================================
# Copy this file to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to version control.
# ============================================================

# --- Proxmox Connection ---
# If using Cloudflare Access proxy: "https://localhost:18006"
# If direct access: "https://<proxmox-ip>:8006"
proxmox_endpoint = "https://localhost:18006"

# Format: USER@REALM!TOKENID=SECRET
proxmox_api_token = "root@pam!mytoken=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# --- Proxmox Node ---
proxmox_node = "pvehp"

# --- Network ---
k3s_master_ip    = "192.168.0.210/24"
k3s_worker_ips   = ["192.168.0.211/24", "192.168.0.212/24"]
k3s_gateway      = "192.168.0.1"
k3s_dns_server   = "192.168.0.1"

# --- Cluster Sizing ---
k3s_master_count  = 1
k3s_worker_count  = 2
k3s_master_cores  = 4
k3s_master_memory = 8192
k3s_worker_cores  = 4
k3s_worker_memory = 8192
k3s_disk_size     = 32

# --- Storage ---
k3s_datastore_id   = "local-lvm"
k3s_network_bridge = "vmbr0"
k3s_vm_start_id    = 200

# --- GitHub Actions ARC ---
# URL for the repository or org (e.g., https://github.com/Overnit or https://github.com/Overnit/landing-page)
github_config_url = "https://github.com/Overnit"
# PAT (ghp_...)
github_pat        = "ghp_xxxxxxxxxxxx"
